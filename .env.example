# Environment Variables for NFL Dashboard
# Copy this file and rename to .env (remove the .example)

# The Odds API Configuration
VITE_ODDS_API_KEY=your_api_key_here

# Optional: Additional API endpoints for enhanced features
# VITE_RAPID_API_KEY=your_rapid_api_key_for_additional_data

# ── M6 vault export (scripts/export-vault-to-md.js) ─────────────────────────
# Set on M6 only. Points at the root of your local Obsidian vault.
# VAULT_DIR=/home/andrewlrose/Obsidian

# Optional filters for the export script
# EXPORT_PREFIX=NFL          # only export notes under this path prefix
# EXPORT_SOURCE=agent        # only export notes created by agents

# Obsidian Local REST API (obsidian-vault-sync.js — M6 only, reverse direction)
# OBSIDIAN_API_URL=https://localhost:27123
# OBSIDIAN_API_KEY=your_obsidian_local_rest_api_key